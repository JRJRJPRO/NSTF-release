# ============================================
# NSTF_MODEL .gitignore
# ============================================

# ====================
# 大文件目录（模型和数据图谱）
# ====================
# 模型文件 (~79GB) - 不上传
models/

# 图谱数据 (pkl文件很大) - 不上传
data/memory_graphs/
data/nstf_graphs/

# ====================
# 敏感配置
# ====================
.env
configs/api_config.json

# ====================
# Python 缓存
# ====================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
.eggs/
*.egg

# ====================
# 实验结果和日志
# ====================
# results/ 目录保留上传
logs/
experiments/results/
experiments/*/results/
*.log

# ====================
# 临时文件
# ====================
*.tmp
*.temp
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ====================
# 备份文件
# ====================
*.backup_*
*.bak

# ====================
# IDE 和编辑器
# ====================
.idea/
.vscode/
*.sublime-*

# ====================
# Jupyter Notebook
# ====================
.ipynb_checkpoints/
