{
  "max_procedures": 5,
  "batch_size": 40,
  "max_content_chars": 150,
  "llm_model": "gemini-2.5-flash",
  "embedding_model": "text-embedding-3-large",
  "api_delay_seconds": 0.5,
  "verify_threshold": 0.25,
  "discover_threshold": 0.20,
  "max_links_per_proc": 10,
  "match_threshold": 0.50,
  "enable_fusion": true,
  "fusion_similarity_threshold": 0.80,
  "step_align_threshold": 0.75,
  "fusion_ema_alpha": 0.3,
  "fusion_min_probability": 0.01,
  "ema_beta": 0.9,
  "drift_threshold": 0.7,
  "anchor_weight": 0.3,
  "use_pattern_mining": true,
  "pattern_min_support": 0.2,
  "pattern_min_length": 2,
  "semantic_threshold": 0.75,
  "use_semantic_clustering": true
}